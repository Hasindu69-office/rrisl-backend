{
  "kind": "collectionType",
  "collectionName": "newsletter_subscribers",
  "info": {
    "singularName": "newsletter-subscriber",
    "pluralName": "newsletter-subscribers",
    "displayName": "newsletter-subscriber"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Email": {
      "type": "email",
      "required": true,
      "minLength": 3,
      "maxLength": 255,
      "unique": true
    },
    "SourcePage": {
      "type": "string",
      "minLength": 3,
      "maxLength": 255,
      "required": true
    },
    "SubscribedAt": {
      "type": "datetime",
      "required": true
    },
    "State": {
      "type": "enumeration",
      "default": "Active",
      "enum": [
        "Active",
        "Inactive"
      ]
    }
  }
}
