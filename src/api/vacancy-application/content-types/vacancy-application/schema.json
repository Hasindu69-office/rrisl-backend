{
  "kind": "collectionType",
  "collectionName": "vacancy_applications",
  "info": {
    "singularName": "vacancy-application",
    "pluralName": "vacancy-applications",
    "displayName": "vacancy application"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "fullname": {
      "type": "string",
      "minLength": 3,
      "maxLength": 255,
      "required": true
    },
    "email": {
      "type": "email",
      "required": true,
      "minLength": 3,
      "maxLength": 255
    },
    "contactnumber": {
      "type": "string",
      "minLength": 3,
      "maxLength": 20,
      "required": true
    },
    "cv": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "files"
      ]
    },
    "state": {
      "type": "enumeration",
      "required": true,
      "default": "submitted",
      "enum": [
        "submitted",
        "reviewing",
        "shortlisted",
        "rejected",
        "accepted"
      ]
    },
    "notes": {
      "type": "text",
      "minLength": 3,
      "maxLength": 255
    },
    "vacancy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::vacancy.vacancy",
      "inversedBy": "vacancy_applications"
    }
  }
}
