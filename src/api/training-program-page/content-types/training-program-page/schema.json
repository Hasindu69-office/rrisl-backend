{
  "kind": "singleType",
  "collectionName": "training_program_pages",
  "info": {
    "singularName": "training-program-page",
    "pluralName": "training-program-pages",
    "displayName": "training program page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "pagehero": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.page-hero",
      "repeatable": false,
      "required": true
    },
    "sectionheader": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.section-header",
      "repeatable": false,
      "required": true
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "minLength": 10,
      "maxLength": 255,
      "required": false
    },
    "trainingprogram": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.tr-programcards",
      "repeatable": true,
      "required": true,
      "max": 2
    },
    "backgroundimage": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
