{
  "kind": "singleType",
  "collectionName": "footers",
  "info": {
    "singularName": "footer",
    "pluralName": "footers",
    "displayName": "footer"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "FooterLogo": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "FooterBackgroundImage": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "TopicandLinks": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "footer.link-group",
      "repeatable": true,
      "required": true,
      "min": 1,
      "max": 2
    },
    "ContactInfo": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "footer.contact-info",
      "repeatable": false,
      "required": true
    },
    "AllrightsreserveText": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "default": "© 2026 Rubber Research Institute of Sri Lanka. All rights reserved.",
      "minLength": 3,
      "maxLength": 255,
      "required": true
    },
    "SocialLinks": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "component": "shared.sociallinks",
      "repeatable": true,
      "required": true,
      "min": 2,
      "max": 4
    }
  }
}
