          "localized": true
        }
      },
      "component": "shared.validationlabels",
      "repeatable": false,
      "required": true
    },
    "contactnumberlabels": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.validationlabels",
      "repeatable": false,
      "required": true
