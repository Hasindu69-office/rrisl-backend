{
  "kind": "singleType",
  "collectionName": "contact_pages",
  "info": {
    "singularName": "contact-page",
    "pluralName": "contact-pages",
    "displayName": "contact page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "pagehero": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.page-hero",
      "repeatable": false,
      "required": true
    },
    "contactinformationdetails": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "contact.contactinformation",
      "repeatable": false,
      "required": true
    },
    "sociallinkscontact": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "contact.sociallinks",
      "repeatable": true
    },
    "headofficeandboardofficedetails": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "contact.locationcards",
      "repeatable": true,
      "max": 2
    },
    "substationtitle": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "default": "Rubber Research Institute",
      "minLength": 3,
      "maxLength": 100,
      "required": true
    },
    "hightlightedtext": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "default": "- Sub-stations",
      "minLength": 3,
      "maxLength": 100,
      "required": true
    },
    "substations": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "contact.substationcard",
      "repeatable": true,
      "required": true,
      "max": 5
    }
  }
}
