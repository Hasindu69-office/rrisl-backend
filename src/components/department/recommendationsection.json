      "repeatable": true
    },
    "includepoints": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "points": {
      "type": "component",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "includepoints"
            },
            true
          ]
        }
      },
      "component": "shared.publicationcards",
      "repeatable": true
    },
    "includetable": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "tablecards": {
      "type": "component",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "includetable"
            },
            true
          ]
        }
